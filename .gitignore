(Binary) Message Formats.md

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg
.venv/
venv/
env/

# Generated protobuf files
python-benchmarks/schemas/*_pb2.py
python-benchmarks/schemas/*_pb2_grpc.py

# Benchmark results
python-benchmarks/results/*.json
!python-benchmarks/results/.gitkeep
go-benchmarks/results/*.json
rust-benchmarks/results/*.json

# Go
go-benchmarks/benchmark
go-benchmarks/schemas/protobuf/*.go
go-benchmarks/schemas/capnp/*.go
go-benchmarks/schemas/flatbuf/*.go

# Rust
rust-benchmarks/benchmark
rust-benchmarks/target/

# Java
java-benchmarks/target/
java-benchmarks/results/*.json
java-benchmarks/dependency-reduced-pom.xml

# Logs / local runtime leftovers
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# .NET
web-app/**/bin/
web-app/**/obj/
*.user
*.suo
.vs/

# IDE
.idea/
*.swp
*.swo
*~
.DS_Store
